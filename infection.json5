{
    "$schema": "vendor/infection/infection/resources/schema.json",
    "source": {
        "directories": ["src"]
    },
    "logs": {
        "text": "php://stderr",
        "summary": "build/infection-summary.log"
    },
    "phpUnit": {
        "configDir": "."
    },
    "minMsi": 98,
    "mutators": {
        "@default": true,
        "TrueValue": {
            "ignore": ["Rasuvaeff\\Yii3Webhooks\\InMemoryNonceStorage"]
        },
        "IncrementInteger": {
            "ignore": ["Rasuvaeff\\Yii3Webhooks\\WebhookSignature"]
        },
        "ConcatOperandRemoval": {
            "ignore": ["Rasuvaeff\\Yii3Webhooks\\WebhookRetryPolicy"]
        }
    }
}
